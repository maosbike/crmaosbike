+  if (!raw) return '';
+  const s = raw.toString().trim();
+  if (/^9\d{8}$/.test(s))   return `+56 9 ${s.slice(1,5)} ${s.slice(5)}`;
+  if (/^569\d{8}$/.test(s)) return `+56 9 ${s.slice(3,7)} ${s.slice(7)}`;
