+
+      {/* Header */}
+      <ViewHeader
+        preheader="Operaciones · Tesorería"
+        title="Pagos a proveedor"
+        subtitle={pending > 0 ? `${pending} sin monto pagado registrado` : null}
+        actions={canCreate && (
