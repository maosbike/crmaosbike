+  icon={Ic.box}               // opcional — ícono grande decorativo
+  title="…"                    // sustantivo, 2–4 palabras
+  hint="…"                     // opcional — una línea con guía/CTA textual
+  action={<Btn>…</Btn>}         // opcional — CTA real
+/>
+
+<Loader label="…" />            // verbo concreto + sustantivo
+```
