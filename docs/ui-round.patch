+* { -webkit-tap-highlight-color: transparent; box-sizing: border-box; }
+
+/* Loader spinner (primitiva ui.jsx) */
+@keyframes crm-spin { to { transform: rotate(360deg); } }
+
+/* ── Drawer: oculto por defecto en TODOS los tamaños ── */
+.crm-drawer {
+  position: fixed;
+  left: 0; top: 0; bottom: 0;
+  width: min(280px, 85vw) !important;
+  transform: translateX(-100%);
+  transition: transform 0.25s ease;
+  pointer-events: none;
+  z-index: 89;
+}
+.crm-drawer.open {
+  transform: translateX(0) !important;
+  pointer-events: auto;
+}
+
+/* En desktop: desactiva el drawer completamente */
+@media (min-width: 768px) {
+  .crm-drawer { display: none !important; }
+}
+
+/* ─── MOBILE  (≤ 767px) ─────────────────────────── */
+@media (max-width: 767px) {
+
+  /* ── Navigation ── */
+  .crm-sidebar   { display: none !important; }
+  .crm-mobile-hdr { display: flex !important; }
+  .crm-desktop-hdr { display: none !important; }
+
+  /* ── Main scroll area padding + no horizontal scroll en mobile ── */
+  .crm-scroll-area { padding: 12px 12px 80px !important; overflow-x: hidden !important; }
+  /* Defensa global: evitar que elementos con min-width/width empujen el viewport.
+     No afecta desktop. */
+  .crm-scroll-area > * { max-width: 100% !important; }
+
+  /* ── Prevent iOS input zoom (needs 16px) ── */
+  input, select, textarea { font-size: 16px !important; }
+
+  /* ── ViewHeader: acciones full-width apiladas en mobile ── */
+  .crm-vh-actions { width: 100% !important; justify-content: stretch !important; }
+  .crm-vh-actions > * { flex: 1 1 auto !important; justify-content: center !important; }
+
+  /* ── Modals: bottom sheet on mobile ── */
+  .crm-modal-overlay { align-items: flex-end !important; padding: 0 !important; }
+  .crm-modal-inner {
+    max-width: 100% !important;
+    width: 100% !important;
+    border-radius: 18px 18px 0 0 !important;
+    max-height: 92vh !important;
+    margin: 0 !important;
+  }
+
+  /* ── Grid collapses ── */
+  .grid-2col { grid-template-columns: 1fr !important; }
+  .grid-3col { grid-template-columns: 1fr !important; }
+  .grid-4col { grid-template-columns: 1fr 1fr !important; }
+
+  /* ── Tables: horizontal scroll ── */
+  .crm-table-scroll { overflow-x: auto !important; -webkit-overflow-scrolling: touch; border-radius: 12px; }
+  .crm-table-scroll table { min-width: 500px; }
+
+  /* ── Ticket detail: stack vertically ── */
+  .crm-ticket-top  { flex-direction: column !important; }
+  .crm-status-panel { min-width: unset !important; width: 100% !important; box-sizing: border-box; }
+  .crm-ticket-cols  { grid-template-columns: 1fr !important; }
+
+  /* ── Tabs: horizontal scroll ── */
+  .crm-tabs { overflow-x: auto !important; -webkit-overflow-scrolling: touch; flex-wrap: nowrap !important; }
+  .crm-tabs button { white-space: nowrap !important; flex-shrink: 0 !important; }
+
+  /* ── Dashboard bottom grid ── */
+  .crm-dash-bottom { grid-template-columns: 1fr !important; }
+
+  /* ── Filter bar wraps ── */
+  .crm-filters { flex-wrap: wrap !important; }
+  .crm-filters .crm-search { min-width: 100% !important; }
+  .crm-filters select { flex: 1 !important; min-width: 130px !important; }
+
+  /* ── Leads list: hide less-important columns ── */
+  .col-hide-mobile { display: none !important; }
+}
+
+/* ─── TABLET (768px – 1024px) ──────────────────── */
+@media (min-width: 768px) and (max-width: 1024px) {
+  .crm-sidebar { width: 180px !important; }
+  .grid-3col    { grid-template-columns: 1fr 1fr !important; }
+  .crm-modal-inner { max-width: 92% !important; }
+  .crm-ticket-cols { grid-template-columns: 1fr !important; }
+}
+
+/* ─── LEADS LIST — mobile card layout ──────────── */
+@media (max-width: 767px) {
+  /* Row wraps into stacked zones */
+  .crm-lead-row { flex-wrap: wrap !important; }
+
+  /* Status strip: horizontal bar full width */
+  .crm-lead-strip {
+    flex: 0 0 100% !important;
+    width: 100% !important;
+    flex-direction: row !important;
+    height: auto !important;
+    min-height: 36px !important;
+    padding: 7px 12px !important;
+    gap: 10px !important;
+    justify-content: flex-start !important;
+    align-items: center !important;
+  }
+
+  /* Moto zone: left ~55% */
+  .crm-lead-moto {
+    flex: 0 0 55% !important;
+    min-width: 0 !important;
+    border-right: none !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+    padding: 10px 10px !important;
+    align-items: center !important;
+  }
+
+  /* Reduce lead image on mobile */
+  .crm-lead-img {
+    width: 70px !important;
+    height: 50px !important;
+  }
+
+  /* Client zone: right ~45% */
+  .crm-lead-client {
+    flex: 0 0 45% !important;
+    min-width: 0 !important;
+    border-right: none !important;
+    border-left: 1px solid #F3F4F6 !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+    padding: 10px 8px !important;
+  }
+
+  /* Status/priority zone: hidden (status shown in strip) */
+  .crm-lead-status { display: none !important; }
+
+  /* Seller zone: full-width footer */
+  .crm-lead-seller {
+    flex: 0 0 100% !important;
+    border-right: none !important;
+    padding: 8px 12px !important;
+  }
+
+  /* Date zone: hidden on mobile */
+  .crm-lead-date { display: none !important; }
+}
+
+/* ─── INVENTORY — mobile card layout ───────────── */
+@media (max-width: 767px) {
+  .crm-inv-card { flex-wrap: wrap !important; }
+
+  /* Branch strip: horizontal full-width bar */
+  .crm-inv-strip {
+    flex: 0 0 100% !important;
+    width: 100% !important;
+    height: auto !important;
+    min-height: 36px !important;
+    padding: 7px 14px !important;
+    flex-direction: row !important;
+    justify-content: flex-start !important;
+    align-items: center !important;
+    font-size: 11px !important;
+  }
+
+  /* Unit (photo + brand): left 55% */
+  .crm-inv-unit {
+    flex: 0 0 55% !important;
+    min-width: 0 !important;
+    border-right: none !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+    padding: 10px 10px !important;
+    gap: 10px !important;
+  }
+
+  /* Reduce unit photo on mobile */
+  .crm-inv-photo {
+    width: 70px !important;
+    height: 70px !important;
+  }
+
+  /* Status: right 45% (paired with unit) */
+  .crm-inv-status {
+    flex: 0 0 45% !important;
+    min-width: 0 !important;
+    border-right: none !important;
+    border-left: 1px solid #F3F4F6 !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+    padding: 10px 10px !important;
+  }
+
+  /* Identifiers (chasis/motor): left 55% */
+  .crm-inv-id {
+    flex: 0 0 55% !important;
+    min-width: 0 !important;
+    border-right: none !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+    padding: 10px 10px !important;
+    gap: 8px !important;
+  }
+
+  /* Price: right 45% (paired with identifiers) */
+  .crm-inv-price {
+    flex: 0 0 45% !important;
+    min-width: 0 !important;
+    border-right: none !important;
+    border-left: 1px solid #F3F4F6 !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+    padding: 10px 10px !important;
+  }
+
+  /* Actions: full width footer */
+  .crm-inv-actions {
+    flex: 0 0 100% !important;
+    padding: 10px 12px !important;
+    flex-direction: row !important;
+    flex-wrap: wrap !important;
+    gap: 6px !important;
+    justify-content: flex-start !important;
+  }
+  .crm-inv-actions button, .crm-inv-actions select {
+    flex: 1 !important;
+    min-width: 100px !important;
+  }
+}
+
+/* ─── TICKET VIEW — breadcrumb + actions ─────── */
+@media (max-width: 767px) {
+  .crm-ticket-breadcrumb {
+    flex-wrap: wrap !important;
+    gap: 4px 6px !important;
+  }
+  .crm-ticket-actions {
+    margin-left: 0 !important;
+    width: 100% !important;
+    justify-content: stretch !important;
+    gap: 6px !important;
+  }
+  .crm-ticket-actions button {
+    flex: 1 !important;
+    font-size: 11px !important;
+    padding: 8px 8px !important;
+    justify-content: center !important;
+  }
+}
+
+/* ─── SALES VIEW — table scroll + form grids ─── */
+@media (max-width: 767px) {
+  .crm-sales-table { overflow-x: auto !important; -webkit-overflow-scrolling: touch !important; border-radius: 12px; }
+  .grid-2col { grid-template-columns: 1fr !important; }
+}
+
+/* ─── CATALOG — edit form grids ─────────────── */
+@media (max-width: 767px) {
+  .crm-cat-grid { grid-template-columns: 1fr !important; }
+}
+
+/* ═══════════════════════════════════════════════════
+   MOBILE RESTRUCTURE — utilidades + bottom nav + fixes
+   ═══════════════════════════════════════════════════ */
+
+/* Utilidades de visibilidad por breakpoint */
+@media (max-width: 767px) {
+  .mob-hide { display: none !important; }
+  /* Grids inline 1fr 1fr que se envuelven con esta clase colapsan a 1 col */
+  .mob-stack { grid-template-columns: 1fr !important; }
+}
+@media (min-width: 768px) {
+  .mob-only { display: none !important; }
+}
+
+/* Bottom nav: visible solo en mobile */
+.crm-bottom-nav { display: none; }
+@media (max-width: 767px) {
+  .crm-bottom-nav {
+    display: flex !important;
+    position: fixed; left: 0; right: 0; bottom: 0;
+    height: 60px;
+    background: #FFFFFF;
+    border-top: 1px solid #E5E7EB;
+    z-index: 70;
+    padding-bottom: env(safe-area-inset-bottom, 0);
+  }
+}
+
+/* NotifBell dropdown: full-width en mobile */
+@media (max-width: 767px) {
+  .crm-notif-dropdown {
+    left: 10px !important;
+    right: 10px !important;
+    width: auto !important;
+    top: 52px !important;
+    max-width: none !important;
+  }
+}
+
+/* SupplierPayments row: apilado en mobile */
+@media (max-width: 767px) {
+  .crm-sp-row { flex-direction: column !important; flex-wrap: nowrap !important; }
+  .crm-sp-row > * {
+    flex: 1 1 auto !important;
+    max-width: none !important;
+    min-width: 0 !important;
+    width: 100% !important;
+    border-right: none !important;
+    border-bottom: 1px solid #F3F4F6 !important;
+  }
+  .crm-sp-row > *:last-child { border-bottom: none !important; }
+}
+
+/* TicketView top grid: 1 col en mobile */
+@media (max-width: 767px) {
+  .crm-tv-top-grid { grid-template-columns: 1fr !important; }
+}
+
+/* Mobile header más compacto (pierde la hamburguesa: el menú vive en bottom nav) */
+@media (max-width: 767px) {
+  .crm-mobile-hdr { height: 48px !important; padding: 0 12px !important; }
+}
diff --git a/frontend/src/tokens.css b/frontend/src/tokens.css
