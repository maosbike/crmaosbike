+  const toCmp = (v) => {
+    if (v == null || v === '') return null;
+    if (isDateSort) {
+      const d = new Date(String(v).slice(0,10) + 'T12:00:00').getTime();
+      return isNaN(d) ? null : d;
+    }
+    if (isNumberSort) {
+      const n = parseInt(v);
+      return isNaN(n) ? null : n;
+    }
