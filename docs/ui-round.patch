+            <button onClick={()=>setDelConfirm(false)} style={S.btn2}>Cancelar</button>
+            <button onClick={handleDelete} style={{...S.btn,background:'#EF4444'}}>Eliminar</button>
+          </div>
+        </Modal>
+      )}
+    </div>
+  );
+}
