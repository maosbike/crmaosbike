+                      </span>
+                    )}
+                  </td>
+
+                  {/* Acciones */}
+                  <td style={{ padding: '6px 8px', textAlign: 'right', whiteSpace: 'nowrap' }} onClick={e => e.stopPropagation()}>
+                    <span style={{ display:'inline-flex', alignItems:'center', gap:4 }}>
+                      {/* Descargar doc */}
+                      <button title={isRes ? 'Ver nota de reserva' : 'Ver nota de venta'}
