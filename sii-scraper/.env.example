# ─── Credenciales SII ────────────────────────────────────────────────────────
# Las usás para que el bot inicie sesión en https://www.sii.cl
# NO commitees el .env real. Solo .env.example va al repo.
SII_RUT=12345678-9
SII_PASSWORD=tu_clave_del_sii
# RUT de la empresa cuyo historial de DTE vas a scrapear (si es el mismo
# del login, lo dejás igual).
SII_EMPRESA_RUT=76.405.840-2

# ─── Conexión al CRM ─────────────────────────────────────────────────────────
# Base URL pública del CRM (sin slash final).
CRM_BASE_URL=https://www.crmaosbike.cl/api
# Token interno: debe coincidir exactamente con INTERNAL_API_TOKEN del CRM.
# Generalo con: openssl rand -hex 32
CRM_INTERNAL_TOKEN=cambiame_es_un_secreto_largo_de_64_chars

# ─── Comportamiento ──────────────────────────────────────────────────────────
# Año a procesar en cada corrida (corte de carga). Para backfill inicial dejá
# 2026 y se itera mes por mes.
TARGET_YEAR=2026

# Si =1, el container hace UNA corrida y se cierra. Útil para testear.
# Si vacío o 0, queda en loop con cron interno cada CRON_HOURS horas.
RUN_ONCE=

# Si =1, ignora el dedupe y baja TODO de nuevo. Solo para emergencias.
FORCE_FULL=

# Cada cuántas horas correr (default 3). Solo aplica si RUN_ONCE no está seteado.
CRON_HOURS=3

# Si =1, además del año actual también procesa el anterior (para pescar
# atrasos típicos de enero).
INCLUDE_PREV_YEAR=

# ─── Debug ───────────────────────────────────────────────────────────────────
# headless=false abre el browser visible. Solo dev local — en Railway NO.
HEADLESS=true
# Carpeta donde guarda PDFs temporales antes de subirlos al CRM.
DOWNLOAD_DIR=/tmp/sii-pdfs
