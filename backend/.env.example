# Railway sets DATABASE_URL automatically
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Generar con: node -e "require('crypto').randomBytes(64).toString('hex')|head -c128"
JWT_SECRET=reemplazar_con_minimo_64_chars_aleatorios
JWT_REFRESH_SECRET=reemplazar_con_minimo_64_chars_aleatorios_distinto_al_anterior
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
PORT=4000
FRONTEND_URL=https://crmaosbike.cl

# Telegram Bot — notificaciones a vendedores
# Obtener token en @BotFather con /newbot
TELEGRAM_BOT_TOKEN=
